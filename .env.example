# ==========================================================
# Mayra AI Sales — Variáveis de ambiente (copie para .env)
# ==========================================================

# ---------- Banco de dados Neon (PostgreSQL) ----------
DATABASE_URL=postgresql://user:password@ep-xxxxx.neon.tech/neondb?sslmode=require

# ---------- Autenticação ----------
JWT_SECRET=troque_por_uma_chave_secreta_bem_longa_e_aleatoria
JWT_EXPIRES_IN=7d

# ---------- Anthropic Claude API ----------
ANTHROPIC_API_KEY=sk-ant-xxxxx
CLAUDE_MODEL=claude-sonnet-4-20250514
# Nome da loja usado pela IA nas conversas (substitui [NOME DA LOJA] no prompt)
STORE_NAME=

# ---------- WhatsApp ----------
# Provedor ativo: "zapi" (SaaS) ou "evolution" (self-hosted)
WHATSAPP_PROVIDER=zapi

# Z-API (quando WHATSAPP_PROVIDER=zapi)
ZAPI_INSTANCE_ID=seu_instance_id
ZAPI_TOKEN=seu_token
ZAPI_BASE_URL=https://api.z-api.io/instances
# Client-Token de segurança da Z-API (opcional, recomendado)
ZAPI_CLIENT_TOKEN=

# Evolution API (quando WHATSAPP_PROVIDER=evolution)
EVOLUTION_BASE_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# Token simples para validar o webhook recebido (opcional)
WEBHOOK_VERIFY_TOKEN=

# ---------- Transcrição de áudio (Speech-to-Text) ----------
# Permite que a IA "entenda" os áudios enviados pelo cliente.
# Compatível com a API da OpenAI. Para usar Groq (cota gratuita):
#   STT_BASE_URL=https://api.groq.com/openai/v1  e  STT_MODEL=whisper-large-v3
STT_PROVIDER=none
STT_API_KEY=
STT_BASE_URL=https://api.openai.com/v1
STT_MODEL=whisper-1
STT_LANGUAGE=pt

# ---------- Storage de arquivos (áudios e imagens) ----------
# Opção A: local (dev)
UPLOAD_DIR=./uploads
# URL pública base para servir os arquivos locais
PUBLIC_BASE_URL=http://localhost:3001
# Opção B: Cloudflare R2 ou AWS S3 (produção) — deixe em branco para usar local
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
S3_REGION=auto

# ---------- Servidor ----------
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ---------- Seed inicial do admin (usado por `npm run seed`) ----------
SEED_ADMIN_NAME=Mayra
SEED_ADMIN_EMAIL=mayra@loja.com
SEED_ADMIN_PASSWORD=mudar123

# ---------- Frontend (Vite) ----------
# Prefixo VITE_ é exposto ao client; defina no client/.env se necessário
VITE_API_URL=http://localhost:3001
